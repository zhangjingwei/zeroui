{
  "schemaVersion": 1,
  "initialState": {
    "loading": { "owner": "client", "value": false },
    "response": { "owner": "server", "value": "" },
    "lastError": { "owner": "client", "value": "" }
  },
  "onMount": {
    "actions": [
      {
        "type": "setState",
        "key": "loading",
        "value": { "type": "literal", "value": true }
      }
    ],
    "effects": [
      {
        "type": "track",
        "event": "fetch_mount_started"
      },
      {
        "type": "http",
        "method": "GET",
        "url": { "type": "literal", "value": "https://httpbin.org/get" },
        "headers": {
          "Accept": { "type": "literal", "value": "application/json" }
        },
        "onSuccess": {
          "actions": [
            {
              "type": "setState",
              "key": "response",
              "value": { "type": "event" }
            },
            {
              "type": "setState",
              "key": "loading",
              "value": { "type": "literal", "value": false }
            }
          ],
          "effects": [
            {
              "type": "track",
              "event": "fetch_success"
            }
          ]
        },
        "onError": {
          "actions": [
            {
              "type": "setState",
              "key": "lastError",
              "value": { "type": "event" }
            },
            {
              "type": "setState",
              "key": "loading",
              "value": { "type": "literal", "value": false }
            }
          ],
          "effects": [
            {
              "type": "track",
              "event": "fetch_error"
            }
          ]
        }
      }
    ]
  },
  "root": {
    "type": "column",
    "spacing": 18,
    "children": [
      {
        "type": "text",
        "text": { "type": "value", "value": "HTTP Demo" },
        "style": "title"
      },
      {
        "type": "text",
        "text": {
          "type": "value",
          "value": "进入页面时自动触发 onMount → GET https://httpbin.org/get。Wave 4 的 page-scoped cancel 在你立刻 back 时会取消这个请求；Wave 5 的 onMount 让 fetch 从「按钮触发」变成「页面进入即加载」。"
        },
        "style": "body",
        "tone": "muted"
      },
      {
        "type": "row",
        "spacing": 12,
        "children": [
          {
            "type": "button",
            "text": "故意打错域名（演示 onError）",
            "variant": "secondary",
            "onClick": {
              "actions": [
                {
                  "type": "setState",
                  "key": "loading",
                  "value": { "type": "literal", "value": true }
                },
                {
                  "type": "setState",
                  "key": "lastError",
                  "value": { "type": "literal", "value": "" }
                }
              ],
              "effects": [
                {
                  "type": "http",
                  "method": "GET",
                  "url": { "type": "literal", "value": "https://this-domain-definitely-does-not-exist-xyz.invalid/anything" },
                  "onSuccess": {
                    "actions": [
                      {
                        "type": "setState",
                        "key": "loading",
                        "value": { "type": "literal", "value": false }
                      }
                    ]
                  },
                  "onError": {
                    "actions": [
                      {
                        "type": "setState",
                        "key": "lastError",
                        "value": { "type": "event" }
                      },
                      {
                        "type": "setState",
                        "key": "loading",
                        "value": { "type": "literal", "value": false }
                      }
                    ]
                  }
                }
              ]
            }
          }
        ]
      },
      {
        "type": "condition",
        "condition": { "type": "truthy", "key": "loading" },
        "child": {
          "type": "card",
          "tone": "primary",
          "children": [
            {
              "type": "text",
              "text": { "type": "value", "value": "加载中..." },
              "style": "label"
            }
          ]
        }
      },
      {
        "type": "condition",
        "condition": { "type": "notBlank", "key": "lastError.error" },
        "child": {
          "type": "card",
          "tone": "muted",
          "children": [
            {
              "type": "text",
              "text": { "type": "value", "value": "请求失败" },
              "style": "label"
            },
            {
              "type": "text",
              "text": {
                "type": "binding",
                "key": "lastError.error",
                "fallback": "(unknown)"
              },
              "style": "body"
            },
            {
              "type": "text",
              "text": {
                "type": "binding",
                "key": "lastError.statusCode",
                "fallback": "0",
                "format": "statusCode = {value}"
              },
              "style": "label",
              "tone": "muted"
            }
          ]
        }
      },
      {
        "type": "condition",
        "condition": { "type": "notBlank", "key": "response.url" },
        "child": {
          "type": "card",
          "tone": "success",
          "children": [
            {
              "type": "text",
              "text": { "type": "value", "value": "响应解析" },
              "style": "sectionTitle"
            },
            {
              "type": "text",
              "text": {
                "type": "binding",
                "key": "response.url",
                "fallback": "",
                "format": "url = {value}"
              },
              "style": "body"
            },
            {
              "type": "text",
              "text": {
                "type": "binding",
                "key": "response.origin",
                "fallback": "",
                "format": "origin = {value}"
              },
              "style": "body"
            },
            {
              "type": "text",
              "text": {
                "type": "binding",
                "key": "response.headers.Host",
                "fallback": "",
                "format": "headers.Host = {value}"
              },
              "style": "body"
            }
          ]
        }
      },
      {
        "type": "row",
        "spacing": 12,
        "children": [
          {
            "type": "button",
            "text": "返回首页",
            "variant": "secondary",
            "onClick": {
              "actions": [],
              "effects": [
                { "type": "back" }
              ]
            }
          }
        ]
      }
    ]
  }
}
