{
  "schemaVersion": 1,
  "initialState": {
    "greetingText": { "owner": "client", "value": "" },
    "inputText": { "owner": "client", "value": "Zero Tools" },
    "selectedTopic": { "owner": "client", "value": "Compose" },
    "clickCount": { "owner": "client", "value": 0 },
    "isDetailVisible": { "owner": "client", "value": true },
    "todos": {
      "owner": "client",
      "value": [
        { "title": "把 SDUI 协议骨架建起来", "done": true },
        { "title": "加 Fallback / ForEach", "done": true },
        { "title": "补 Parser / Reducer 测试", "done": true },
        { "title": "虚拟业务：客户资料补全", "done": false }
      ]
    }
  },
  "root": {
    "type": "column",
    "spacing": 18,
    "children": [
      {
        "type": "text",
        "text": { "type": "value", "value": "ZeroUI Demo" },
        "style": "title"
      },
      {
        "type": "text",
        "text": {
          "type": "value",
          "value": "JSON 现在同时描述 UI、状态归属、Action 和 Effect，Renderer 只负责消费模型。"
        },
        "style": "body",
        "tone": "muted"
      },
      {
        "type": "textField",
        "label": "页面标题",
        "value": { "type": "binding", "key": "inputText", "fallback": "Zero Tools" },
        "onValueChange": {
          "actions": [
            {
              "type": "setState",
              "key": "inputText",
              "value": { "type": "event" }
            }
          ]
        },
        "layout": { "fillMaxWidth": true }
      },
      {
        "type": "chipGroup",
        "selectedKey": "selectedTopic",
        "onSelected": {
          "actions": [
            {
              "type": "setState",
              "key": "selectedTopic",
              "value": { "type": "event" }
            },
            {
              "type": "setState",
              "key": "greetingText",
              "value": { "type": "template", "value": "hello world from {event}" }
            }
          ],
          "effects": [
            {
              "type": "log",
              "message": { "type": "template", "value": "topic selected: {event}" }
            }
          ]
        },
        "spacing": 8,
        "options": [
          { "label": "Compose", "value": "Compose" },
          { "label": "事件", "value": "Event" },
          { "label": "状态", "value": "State" }
        ]
      },
      {
        "type": "row",
        "spacing": 12,
        "children": [
          {
            "type": "button",
            "text": "输出 hello world",
            "onClick": {
              "actions": [
                {
                  "type": "setState",
                  "key": "greetingText",
                  "value": { "type": "literal", "value": "hello world" }
                },
                {
                  "type": "incrementState",
                  "key": "clickCount",
                  "step": 1
                }
              ],
              "effects": [
                {
                  "type": "toast",
                  "message": { "type": "literal", "value": "已输出 hello world" }
                },
                {
                  "type": "track",
                  "event": "home_hello_clicked",
                  "params": {
                    "topic": { "type": "state", "key": "selectedTopic" },
                    "clicks": { "type": "state", "key": "clickCount" }
                  }
                }
              ]
            }
          },
          {
            "type": "button",
            "text": "清空",
            "variant": "secondary",
            "onClick": {
              "actions": [
                {
                  "type": "setState",
                  "key": "greetingText",
                  "value": { "type": "literal", "value": "" }
                },
                {
                  "type": "setState",
                  "key": "clickCount",
                  "value": { "type": "literal", "value": 0 }
                }
              ]
            }
          }
        ]
      },
      {
        "type": "switch",
        "text": "显示详情卡片",
        "checkedKey": "isDetailVisible",
        "onCheckedChange": {
          "actions": [
            {
              "type": "setState",
              "key": "isDetailVisible",
              "value": { "type": "event" }
            }
          ]
        }
      },
      {
        "type": "card",
        "tone": "primary",
        "children": [
          {
            "type": "text",
            "text": { "type": "binding", "key": "inputText", "fallback": "Card 输出区域" },
            "style": "sectionTitle"
          },
          {
            "type": "text",
            "text": {
              "type": "binding",
              "key": "greetingText",
              "fallback": "点击按钮后，这里会显示 hello world"
            },
            "style": "body"
          },
          {
            "type": "text",
            "text": {
              "type": "binding",
              "key": "clickCount",
              "fallback": "0",
              "format": "点击次数：{value}"
            },
            "style": "label",
            "tone": "muted"
          },
          {
            "type": "condition",
            "condition": { "type": "notBlank", "key": "greetingText" },
            "child": {
              "type": "text",
              "text": {
                "type": "binding",
                "key": "selectedTopic",
                "fallback": "Compose",
                "format": "当前主题：{value}"
              },
              "style": "label",
              "tone": "success"
            }
          }
        ]
      },
      {
        "type": "condition",
        "condition": { "type": "truthy", "key": "isDetailVisible" },
        "child": {
          "type": "column",
          "spacing": 12,
          "children": [
            {
              "type": "text",
              "text": { "type": "value", "value": "协议分层" },
              "style": "sectionTitle"
            },
            {
              "type": "card",
              "tone": "muted",
              "children": [
                {
                  "type": "text",
                  "text": { "type": "value", "value": "1. State 带 owner：server / client / shared" },
                  "style": "label"
                },
                {
                  "type": "text",
                  "text": { "type": "value", "value": "2. Interaction = actions + effects" },
                  "style": "label"
                },
                {
                  "type": "text",
                  "text": { "type": "value", "value": "3. Action 只更新状态，Effect 只执行副作用" },
                  "style": "label"
                },
                {
                  "type": "text",
                  "text": { "type": "value", "value": "4. Renderer 不知道 JSON，也不直接执行业务逻辑" },
                  "style": "label",
                  "tone": "success"
                }
              ]
            }
          ]
        }
      },
      {
        "type": "text",
        "text": { "type": "value", "value": "TODO 列表（forEach + item scope）" },
        "style": "sectionTitle"
      },
      {
        "type": "forEach",
        "itemsKey": "todos",
        "spacing": 8,
        "child": {
          "type": "card",
          "tone": "muted",
          "padding": 12,
          "spacing": 4,
          "children": [
            {
              "type": "text",
              "text": {
                "type": "binding",
                "key": "item.title",
                "fallback": "(missing title)"
              },
              "style": "label"
            },
            {
              "type": "text",
              "text": {
                "type": "binding",
                "key": "item.done",
                "fallback": "false",
                "format": "完成：{value}"
              },
              "style": "body",
              "tone": "muted"
            }
          ]
        }
      },
      {
        "type": "condition",
        "condition": {
          "type": "expr",
          "expression": {
            "type": "binary",
            "op": ">",
            "lhs": { "type": "ref", "key": "clickCount" },
            "rhs": { "type": "lit", "value": 3 }
          }
        },
        "child": {
          "type": "card",
          "tone": "success",
          "children": [
            {
              "type": "text",
              "text": { "type": "value", "value": "Expression 演示：点击 4 次以上才会显示这段" },
              "style": "label"
            }
          ]
        }
      },
      {
        "type": "row",
        "spacing": 12,
        "children": [
          {
            "type": "button",
            "text": "跳到 Detail 页",
            "onClick": {
              "actions": [],
              "effects": [
                {
                  "type": "navigate",
                  "target": { "type": "literal", "value": "detail" }
                },
                {
                  "type": "track",
                  "event": "home_to_detail_clicked"
                }
              ]
            }
          },
          {
            "type": "button",
            "text": "跳到 Fetch Demo（Http）",
            "variant": "secondary",
            "onClick": {
              "actions": [],
              "effects": [
                {
                  "type": "navigate",
                  "target": { "type": "literal", "value": "fetch" }
                }
              ]
            }
          },
          {
            "type": "button",
            "text": "查看 Showcase",
            "variant": "secondary",
            "onClick": {
              "actions": [],
              "effects": [
                {
                  "type": "navigate",
                  "target": { "type": "literal", "value": "showcase" }
                },
                {
                  "type": "track",
                  "event": "home_to_showcase_clicked"
                }
              ]
            }
          }
        ]
      },
      {
        "type": "future",
        "comment": "下面这个 type 客户端不认识，应该走 Node.Unknown 占位兜底",
        "payload": { "any": "thing" }
      }
    ]
  }
}
